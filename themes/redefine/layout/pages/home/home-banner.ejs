<!-- Элемент для предварительного рендеринга backdrop-filter -->
<div class="backdrop-filter-prerender"></div>

<script data-swup-reload-script>
    // Функция для оптимизации контейнера с закрепленными постами
    function optimizeMobilePostsContainer() {
        // Элементы, которые нужно оптимизировать
        const postsContainer = document.querySelector('.mobile-important-posts-container');
        
        if (!postsContainer) return;
        
        // Установка начальных стилей для плавного появления
        postsContainer.classList.add('preloaded');
        
        // Обработчик для SWUP-переходов
        try {
            if (typeof swup !== 'undefined') {
                // Предварительная обработка перед появлением страницы
                swup.hooks.on('page:view', function() {
                    setTimeout(function() {
                        const newPostsContainer = document.querySelector('.mobile-important-posts-container');
                        if (newPostsContainer) {
                            newPostsContainer.classList.add('preloaded');
                        }
                    }, 50);
                });
            }
        } catch (e) {
            console.warn('SWUP недоступен для оптимизации контейнера', e);
        }
    }
    
    // Запускаем оптимизацию после загрузки DOM
    document.addEventListener('DOMContentLoaded', optimizeMobilePostsContainer);
    
    // Экспортируем функцию для возможности вызова из других скриптов
    window.optimizeMobilePostsContainer = optimizeMobilePostsContainer;
</script>

<!-- Мгновенное скрытие мобильного контейнера на ПК -->
<script>
    // Запускаем немедленно, без ожидания загрузки DOM
    (function() {
        if (window.innerWidth >= 769) {
            // На ПК немедленно скрываем мобильный контейнер
            const mobileContainers = document.querySelectorAll('.mobile-important-posts-static, .mobile-video-container, .hide-on-pc');
            mobileContainers.forEach(container => {
                if (container) {
                    container.style.display = 'none';
                    container.style.visibility = 'hidden';
                    container.style.opacity = '0';
                    container.style.position = 'absolute';
                    container.style.left = '-9999px';
                    container.style.pointerEvents = 'none';
                    // Отключаем анимации для скрытых контейнеров
                    container.style.animation = 'none';
                }
            });
            
            // Отключаем ненужные анимации на ПК для оптимизации
            document.addEventListener('DOMContentLoaded', function() {
                // Используем requestAnimationFrame для выполнения после отрисовки
                requestAnimationFrame(function() {
                    // Ограничиваем частоту обновления rainbow-glow анимации на больших экранах
                    const style = document.createElement('style');
                    style.innerHTML = `
                        @media (min-width: 769px) {
                            .glow-text {
                                animation-duration: 12s !important; /* Замедляем анимацию для экономии ресурсов */
                            }
                        }
                    `;
                    document.head.appendChild(style);
                });
            });
        }
    })();
</script>

