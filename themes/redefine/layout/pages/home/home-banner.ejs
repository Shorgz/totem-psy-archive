    <script data-swup-reload-script>
        document.addEventListener('DOMContentLoaded', function() {
            // Глобальный обработчик для нажатия на видео-контейнер, работающий даже после SWUP-переходов
            document.body.addEventListener('click', function(e) {
                // Находим ближайший видео-контейнер или его обертку от места клика
                const videoWrapper = e.target.closest('.mobile-video-wrapper');
                
                if (videoWrapper) {
                    console.log("Глобальный обработчик: клик на видео-контейнер");
                    
                    // Получаем ссылки на элементы
                    const fullscreenContainer = document.getElementById('fullscreen-video-container-mobile');
                    const topLeftContainer = document.querySelector('.top-left-container');
                    const fixedPostsContainers = document.querySelectorAll('.fixed-important-posts-container, .mobile-important-posts-static');
                    const smallVideo = document.getElementById('mobileThumbnailVideo');
                    
                    // Проверяем наличие полноэкранного контейнера
                    if (!fullscreenContainer) {
                        console.error("Контейнер для полноэкранного видео не найден");
                        return;
                    }
                    
                    // Паузим малое видео
                    if (smallVideo) {
                        console.log("Ставим малое видео на паузу");
                        smallVideo.pause();
                    }
                    
                    // Показываем полноэкранный режим
                    fullscreenContainer.style.display = 'flex';
                    fullscreenContainer.style.zIndex = '9999999999';
                    
                    // Скрываем другие элементы
                    if (topLeftContainer) {
                        topLeftContainer.style.zIndex = '-999';
                        topLeftContainer.style.visibility = 'hidden';
                        topLeftContainer.style.opacity = '0';
                        topLeftContainer.style.pointerEvents = 'none';
                    }
                    
                    fixedPostsContainers.forEach(container => {
                        container.style.zIndex = '-999';
                        container.style.visibility = 'hidden';
                        container.style.opacity = '0';
                        container.style.pointerEvents = 'none';
                    });
                    
                    // Добавляем класс-маркер
                    document.body.classList.add('video-is-open');
                    
                    // Блокируем скролл
                    document.body.style.overflow = 'hidden';
                    
                    // Запускаем полноэкранное видео
                    const bigVideo = document.getElementById('fullscreenVideoMobile');
                    if (bigVideo) {
                        bigVideo.currentTime = 0;
                        const playPromise = bigVideo.play();
                        if (playPromise !== undefined) {
                            playPromise.catch(err => {
                                console.error("Ошибка воспроизведения видео:", err);
                            });
                        }
                    }
                    
                    // Предотвращаем всплытие события
                    e.preventDefault();
                    e.stopPropagation();
                }
            });
            
            // Глобальный обработчик для закрытия полноэкранного видео
            document.body.addEventListener('click', function(e) {
                // Находим ближайшую кнопку закрытия от места клика
                const closeButton = e.target.closest('.close-fullscreen');
                const fullscreenContainer = document.getElementById('fullscreen-video-container-mobile');
                
                // Если клик был на кнопке закрытия или на самом контейнере (но не на его дочерних элементах)
                if ((closeButton || (fullscreenContainer && e.target === fullscreenContainer)) && fullscreenContainer.style.display === 'flex') {
                    console.log("Глобальный обработчик: закрытие видео");
                    
                    // Ставим большое видео на паузу
                    const bigVideo = document.getElementById('fullscreenVideoMobile');
                    if (bigVideo) {
                        console.log("Ставим большое видео на паузу");
                        bigVideo.pause();
                    }
                    
                    // Скрываем контейнер
                    fullscreenContainer.style.display = 'none';
                    
                    // Восстанавливаем элементы
                    const topLeftContainer = document.querySelector('.top-left-container');
                    if (topLeftContainer) {
                        topLeftContainer.style.zIndex = '';
                        topLeftContainer.style.visibility = '';
                        topLeftContainer.style.opacity = '';
                        topLeftContainer.style.pointerEvents = '';
                    }
                    
                    const fixedPostsContainers = document.querySelectorAll('.fixed-important-posts-container, .mobile-important-posts-static');
                    fixedPostsContainers.forEach(container => {
                        container.style.zIndex = '';
                        container.style.visibility = '';
                        container.style.opacity = '';
                        container.style.pointerEvents = '';
                    });
                    
                    // Удаляем класс-маркер
                    document.body.classList.remove('video-is-open');
                    
                    // Восстанавливаем скролл
                    document.body.style.overflow = '';
                    
                    // Запускаем малое видео на главной странице
                    if (isHomePage()) {
                        const smallVideo = document.getElementById('mobileThumbnailVideo');
                        if (smallVideo) {
                            console.log("Запускаем воспроизведение малого видео");
                            setTimeout(() => {
                                const playPromise = smallVideo.play();
                                if (playPromise !== undefined) {
                                    playPromise.catch(err => {
                                        console.warn("Ошибка воспроизведения малого видео:", err);
                                    });
                                }
                            }, 100);
                        }
                    }
                    
                    // Предотвращаем всплытие события
                    e.preventDefault();
                    e.stopPropagation();
                }
            });
            
            function initMobileVideo() {
                console.log("Инициализация мобильного видео");
                
                // Проверка видимости мобильного видеоконтейнера
                function updateMobileVideoVisibility() {
                    try {
                        const currentPath = window.location.pathname;
                        const isHome = isHomePage();
                        console.log("Проверка видимости видео, текущий путь:", currentPath, "isHomePage:", isHome);
                        
                        // Получаем элементы
                        const container = document.querySelector('.mobile-video-container');
                        const video = document.getElementById('mobileThumbnailVideo');
                        
                        if (!container || !video) {
                            console.log("Элементы не найдены, прерываем обновление");
                            return;
                        }
                        
                        if (window.innerWidth <= 768 && isHome) {
                            console.log("Показываем видео контейнер");
                            container.style.display = 'block';
                            
                            // Проверяем, не открыто ли полноэкранное видео
                            const isVideoOpen = document.body.classList.contains('video-is-open');
                            if (isVideoOpen) {
                                console.log("Полноэкранное видео открыто, не запускаем малое видео");
                                return;
                            }
                            
                            // Проверяем, находится ли видео в области видимости
                            if (isElementInViewport(container) && video.paused) {
                                console.log("Запускаем воспроизведение малого видео");
                                const playPromise = video.play();
                                if (playPromise !== undefined) {
                                    playPromise.catch(err => {
                                        console.warn("Ошибка автозапуска видео:", err);
                                    });
                                }
                            }
                        } else {
                            console.log("Скрываем видео контейнер");
                            container.style.display = 'none';
                            
                            // Ставим видео на паузу, если мы не на главной
                            if (video && !video.paused) {
                                console.log("Ставим видео на паузу, т.к. не на главной");
                                video.pause();
                            }
                        }
                    } catch (e) {
                        console.error("Ошибка при обновлении видимости видео:", e);
                    }
                }
                
                // Функция для проверки, находится ли элемент в области видимости
                function isElementInViewport(el) {
                    if (!el) return false;
                    
                    const rect = el.getBoundingClientRect();
                    
                    // Учитываем только вертикальное положение
                    return (
                        rect.top >= -rect.height &&
                        rect.top <= window.innerHeight
                    );
                }
                
                // Обработчик прокрутки для управления воспроизведением видео
                function handleVideoOnScroll() {
                    // Работаем только на главной странице и на мобильных устройствах
                    if (!isHomePage() || window.innerWidth > 768) return;
                    
                    // Получаем видео контейнер и видео элемент
                    const container = document.querySelector('.mobile-video-container');
                    const video = document.getElementById('mobileThumbnailVideo');
                    
                    if (!container || !video) return;
                    
                    // Проверяем, открыто ли полноэкранное видео
                    const isVideoOpen = document.body.classList.contains('video-is-open');
                    if (isVideoOpen) return;
                    
                    // Проверяем видимость видео
                    if (isElementInViewport(container)) {
                        // Видео в зоне видимости - воспроизводим, если оно на паузе
                        if (video.paused) {
                            console.log("Возобновляем воспроизведение видео после прокрутки");
                            const playPromise = video.play();
                            if (playPromise !== undefined) {
                                playPromise.catch(err => {
                                    console.warn("Ошибка возобновления видео:", err);
                                });
                            }
                        }
                    } else {
                        // Видео не в зоне видимости - ставим на паузу
                        if (!video.paused) {
                            console.log("Ставим видео на паузу, так как оно вне экрана");
                            video.pause();
                        }
                    }
                }
                
                // Обработчик для видео
                const videoElement = document.getElementById('mobileThumbnailVideo');
                if (videoElement) {
                    // Обработчик окончания видео
                    videoElement.addEventListener('ended', function() {
                        console.log('Малое видео завершилось, начинаем заново');
                        if (isHomePage() && !document.body.classList.contains('video-is-open')) {
                            videoElement.currentTime = 0;
                            videoElement.play().catch(err => {
                                console.warn('Ошибка при перезапуске видео:', err);
                            });
                        }
                    });
                    
                    // Обработчик ошибок
                    videoElement.addEventListener('error', function(e) {
                        console.error('Ошибка видео:', e);
                        // Пробуем перезагрузить
                        setTimeout(() => {
                            const currentSrc = videoElement.currentSrc;
                            videoElement.src = '';
                            videoElement.src = currentSrc;
                            videoElement.load();
                        }, 1000);
                    });
                }
                
                // Инициализируем видимость
                updateMobileVideoVisibility();
                
                // Обработчик прокрутки страницы для видео
                window.addEventListener('scroll', handleVideoOnScroll, { passive: true });
                
                // Обновляем при изменении размера окна
                window.addEventListener('resize', updateMobileVideoVisibility);
                
                return { 
                    updateMobileVideoVisibility,
                    handleVideoOnScroll
                };
            }
            
            // Функция для проверки главной страницы
            function isHomePage() {
                const path = window.location.pathname;
                return path === '/' || path === '/index.html' || path === '/index.php';
            }
            
            // Запускаем инициализацию
            const { updateMobileVideoVisibility, handleVideoOnScroll } = initMobileVideo();
            
            // Обработка SWUP
            try {
                if (typeof swup !== 'undefined') {
                    // Обновление при всех переходах
                    swup.hooks.on('page:view', function() {
                        console.log("SWUP page:view");
                        setTimeout(() => {
                            // Инициализация только на главной странице
                            if (isHomePage()) {
                                console.log("Мы на главной странице - инициализируем видео");
                                initMobileVideo();
                                updateMobileVideoVisibility();
                            }
                        }, 100);
                    });
                    
                    swup.hooks.on('animation:in:end', function() {
                        console.log("SWUP animation:in:end");
                        setTimeout(() => {
                            if (isHomePage()) {
                                updateMobileVideoVisibility();
                            }
                        }, 200);
                    });
                }
            } catch (e) {
                console.error('SWUP не найден или произошла ошибка:', e);
            }
        });
    </script>
</div>

