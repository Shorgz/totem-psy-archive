<script data-swup-reload-script>
  document.addEventListener('DOMContentLoaded', function() {
    var container = document.querySelector('.mobile-important-posts-container');
    var expandBtn = document.getElementById('expandMobilePosts');
    var barLetters = document.querySelectorAll('.bar-letter');
    var verticalBar = document.querySelector('.vertical-bar');
    if (!container || !expandBtn) return;
    var expanded = false;
    
    // Подготовка SVG для анимации
    var svg = expandBtn.querySelector('svg');
    svg.innerHTML = '<path fill="#1976d2" d="M12 16l-6-6h12z" class="arrow-path"/>';
    svg.classList.add('expand-arrow');
    
    function toggleExpand(e) {
      e.stopPropagation();
      expanded = !expanded;
      container.classList.toggle('expanded', expanded);
      
      // Плавная анимация поворота стрелки с упругим эффектом
      expandBtn.querySelector('svg').style.transition = 'transform 0.7s cubic-bezier(0.34, 1.56, 0.64, 1)';
      expandBtn.querySelector('svg').style.transform = expanded ? 'rotate(270deg) scale(1.1)' : 'rotate(90deg)';
      
      // Добавляем класс для анимации SVG
      expandBtn.querySelector('svg').classList.toggle('expanded-arrow', expanded);
      
      // Добавим временный класс для анимации ripple-эффекта при клике
      expandBtn.classList.add('button-clicked');
      setTimeout(() => {
        expandBtn.classList.remove('button-clicked');
      }, 700);
      
      // Анимация появления/исчезновения текста
      var links = container.querySelectorAll('a');
      
      if (expanded) {
        // Разворачивание контейнера: плавное появление текста
        links.forEach(function(link, index) {
          link.style.opacity = '0';
          link.style.transform = 'translateX(-10px)';
          
          // Задержка для каждой следующей ссылки
          setTimeout(function() {
            link.style.opacity = '1';
            link.style.transform = 'translateX(0)';
          }, 100 + (index * 50)); // Увеличивающаяся задержка для эффекта каскада
        });
      } else {
        // Сохраняем текущее состояние ссылок видимым, пока идет анимация закрытия
        links.forEach(function(link) {
          // Используем transition только для transform, чтобы избежать мерцания opacity
          link.style.transition = 'transform 0.3s ease';
          link.style.transform = 'translateX(-5px)';
          // Сохраняем opacity без изменений
          link.style.opacity = '1';
        });
        
        // Сбрасываем стили после завершения анимации закрытия
        setTimeout(function() {
          // Первым делом мягко возвращаем ссылки в исходное положение
          links.forEach(function(link) {
            // Не отключаем transition, а делаем его быстрым и плавным
            link.style.transition = 'transform 0.2s ease-out';
            link.style.opacity = '1';
            link.style.transform = 'translateX(0)';
          });
          
          // Затем сбрасываем стили контейнера
          container.removeAttribute('style');
          
          // И только после полного завершения анимации возвращения текста
          // сбрасываем transition, чтобы не влиять на будущие анимации
          setTimeout(function() {
            links.forEach(function(link) {
              // Теперь можно безопасно сбросить transition для будущих анимаций
              link.style.transition = '';
            });
          }, 200);
        }, 350);
        
        return; // Предотвращаем немедленное удаление стилей
      }
      
      container.removeAttribute('style');
    }
    
    expandBtn.addEventListener('click', toggleExpand);
    barLetters.forEach(function(letter) {
      letter.style.cursor = 'pointer';
      letter.addEventListener('click', toggleExpand);
    });
    
    // Оптимизация для предотвращения мерцания
    function optimizeVerticalBar() {
      if (verticalBar) {
        // Добавляем класс для предзагрузки
        verticalBar.classList.add('preloaded');
      }
    }
    
    // Запускаем оптимизацию сразу
    optimizeVerticalBar();
    
    // Поддержка SWUP - инициализация после перехода между страницами
    try {
      if (typeof swup !== 'undefined') {
        swup.hooks.on('page:view', function() {
          // Переинициализация при новом просмотре страницы
          setTimeout(function() {
            container = document.querySelector('.mobile-important-posts-container');
            expandBtn = document.getElementById('expandMobilePosts');
            barLetters = document.querySelectorAll('.bar-letter');
            verticalBar = document.querySelector('.vertical-bar');
            
            if (!container || !expandBtn) return;
            expanded = false;
            expandBtn.addEventListener('click', toggleExpand);
            barLetters.forEach(function(letter) {
              letter.style.cursor = 'pointer';
              letter.addEventListener('click', toggleExpand);
            });
            
            // Повторная оптимизация вертикальной полосы
            optimizeVerticalBar();
          }, 50);
        });
      }
    } catch (e) {
      console.log('SWUP не найден, используем стандартный режим инициализации.');
    }
  });
</script>

