<!DOCTYPE html>
<html lang="<%= config.language %>">
<%- partial('components/header/head') %>

<body>
	<%- body %>
	<%- partial('components/scripts') %>
	<% if (theme.plugins.aplayer.enable) { %>
	<%- partial('components/plugins/aplayer') %>
	<% } %>
	
	<!-- Фиксированный контейнер с важными постами (только на главной странице) -->
	<% if (is_home()) { %>
	<%- partial('components/fixed-posts') %>
	<% } %>
	
	<!-- Скрипт для создания tl_article_content если его нет -->
	<script>
	document.addEventListener('DOMContentLoaded', function() {
		// Проверяем находимся ли мы на странице статьи
		if (document.querySelector('.article-content-container')) {
			// Убедимся что структура с tl_article_content уже есть, если нет - создадим
			if (!document.querySelector('.article-content article.tl_article_content')) {
				console.log('Создаем структуру article.tl_article_content с клиентской стороны');
				
				// Ищем контейнер содержимого
				const contentContainer = document.querySelector('.article-content .markdown-body');
				if (!contentContainer) return;
				
				// Сохраняем содержимое
				const content = contentContainer.innerHTML;
				
				// Очищаем контейнер
				contentContainer.innerHTML = '';
				
				// Создаем новую структуру
				const articleWrapper = document.createElement('div');
				articleWrapper.className = 'article medium-article';
				
				const article = document.createElement('article');
				article.className = 'tl_article_content';
				article.id = '_tl_editor';
				article.innerHTML = content;
				
				// Собираем структуру
				articleWrapper.appendChild(article);
				contentContainer.appendChild(articleWrapper);
			}
			
			// Оптимизируем изображения для Telegram Instant View
			setTimeout(function() {
				// Получаем элемент article.tl_article_content
				const articleContent = document.querySelector('.article-content article.tl_article_content');
				if (!articleContent) return;
				
				// Обработка всех элементов с inline стилями
				const styledElements = articleContent.querySelectorAll('[style]');
				styledElements.forEach(function(el) {
					// Проверяем есть ли изображения внутри
					const img = el.querySelector('img');
					if (img) {
						// Получаем src изображения
						const src = img.dataset.src || img.src;
						
						// Создаем figure
						const figure = document.createElement('figure');
						
						// Создаем новое изображение
						const newImg = document.createElement('img');
						newImg.src = src;
						
						// Создаем figcaption
						const figcaption = document.createElement('figcaption');
						
						// Добавляем элементы в figure
						figure.appendChild(newImg);
						figure.appendChild(figcaption);
						
						// Заменяем стилизованный элемент на figure
						el.parentElement.replaceChild(figure, el);
					}
				});
				
				// Обработка div с атрибутом align
				const alignDivs = articleContent.querySelectorAll('div[align]');
				alignDivs.forEach(function(div) {
					// Проверяем содержимое на наличие изображений
					const img = div.querySelector('img');
					if (img) {
						// Получаем src изображения
						const src = img.dataset.src || img.src;
						
						// Создаем figure
						const figure = document.createElement('figure');
						
						// Создаем новое изображение
						const newImg = document.createElement('img');
						newImg.src = src;
						
						// Создаем figcaption
						const figcaption = document.createElement('figcaption');
						
						// Добавляем элементы в figure
						figure.appendChild(newImg);
						figure.appendChild(figcaption);
						
						// Заменяем стилизованный элемент на figure
						div.parentElement.replaceChild(figure, div);
					}
				});
				
				// Находим все изображения
				const images = articleContent.querySelectorAll('img');
				images.forEach(function(img) {
					// Если изображение не внутри figure, оборачиваем его
					if (img.parentElement.tagName !== 'FIGURE') {
						// Получаем src (учитываем ленивую загрузку)
						const src = img.dataset.src || img.src;
						
						// Создаем figure
						const figure = document.createElement('figure');
						
						// Создаем новое изображение
						const newImg = document.createElement('img');
						newImg.src = src;
						
						// Создаем figcaption
						const figcaption = document.createElement('figcaption');
						
						// Добавляем элементы в figure
						figure.appendChild(newImg);
						figure.appendChild(figcaption);
						
						// Заменяем старое изображение на figure
						img.parentElement.replaceChild(figure, img);
					} else {
						// Если изображение уже внутри figure, просто очищаем атрибуты
						img.src = img.dataset.src || img.src;
						
						// Удаляем лишние атрибуты
						img.removeAttribute('data-src');
						img.removeAttribute('loading');
						img.removeAttribute('lazyload');
						img.removeAttribute('class');
						img.removeAttribute('style');
						img.removeAttribute('alt');
						
						// Проверяем, есть ли figcaption
						const figure = img.parentElement;
						if (!figure.querySelector('figcaption')) {
							const figcaption = document.createElement('figcaption');
							figure.appendChild(figcaption);
						}
						
						// Удаляем классы у figure
						figure.removeAttribute('class');
					}
				});
				
				// Находим все div с style="text-align: center" и другими
				const styleDivs = articleContent.querySelectorAll('div[style*="text-align"]');
				styleDivs.forEach(function(div) {
					// Проверяем, содержит ли div изображение
					const img = div.querySelector('img');
					if (img) {
						// Создаем figure
						const figure = document.createElement('figure');
						
						// Получаем src
						const src = img.dataset.src || img.src;
						
						// Создаем новое изображение
						const newImg = document.createElement('img');
						newImg.src = src;
						
						// Создаем figcaption
						const figcaption = document.createElement('figcaption');
						
						// Добавляем элементы в figure
						figure.appendChild(newImg);
						figure.appendChild(figcaption);
						
						// Заменяем div на figure
						div.parentElement.replaceChild(figure, div);
					}
				});
				
				// Обработка p с изображениями (часто встречается в markdown)
				const paragraphs = articleContent.querySelectorAll('p');
				paragraphs.forEach(function(p) {
					// Проверяем, содержит ли p только изображение
					if (p.childNodes.length === 1 && p.querySelector('img')) {
						const img = p.querySelector('img');
						const src = img.dataset.src || img.src;
						
						// Создаем figure
						const figure = document.createElement('figure');
						
						// Создаем новое изображение
						const newImg = document.createElement('img');
						newImg.src = src;
						
						// Создаем figcaption
						const figcaption = document.createElement('figcaption');
						
						// Добавляем элементы в figure
						figure.appendChild(newImg);
						figure.appendChild(figcaption);
						
						// Заменяем p на figure
						p.parentElement.replaceChild(figure, p);
					}
				});
				
				// Еще раз проверяем для надежности, что все изображения обработаны
				const finalCheck = articleContent.querySelectorAll('img:not(figure > img)');
				finalCheck.forEach(function(img) {
					// Создаем figure
					const figure = document.createElement('figure');
					
					// Создаем новое изображение
					const newImg = document.createElement('img');
					newImg.src = img.dataset.src || img.src;
					
					// Создаем figcaption
					const figcaption = document.createElement('figcaption');
					
					// Добавляем элементы в figure
					figure.appendChild(newImg);
					figure.appendChild(figcaption);
					
					// Заменяем изображение на figure
					img.parentElement.replaceChild(figure, img);
				});
			}, 100);
		}
	});
	</script>
</body>

</html>