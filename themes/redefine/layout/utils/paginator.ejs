<div class="paginator">
	<%- paginator({
    prev_text: '<i class="fa-regular fa-angle-left"></i>',
    next_text: '<i class="fa-regular fa-angle-right"></i>',
    escape: false
	}) %>
</div>

<script>
    // Добавляем обработчик событий для кнопок пагинации
    document.addEventListener('DOMContentLoaded', function() {
        // Получаем все ссылки пагинации
        const paginationLinks = document.querySelectorAll('.paginator a');
        
        // Добавляем обработчик клика для обновления рекламы
        paginationLinks.forEach(function(link) {
            link.addEventListener('click', function() {
                // Добавляем небольшую задержку для уверенности, что новая страница загрузится
                setTimeout(function() {
                    if (typeof fillPromoContainers === 'function') {
                        fillPromoContainers();
                    }
                }, 100);
            });
        });
    });
</script>
  