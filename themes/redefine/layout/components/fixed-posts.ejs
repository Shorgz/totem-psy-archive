<!-- Специальные стили для браузеров без JavaScript -->
<noscript>
    <style>
        @media (max-width: 768px) {
            .fixed-important-posts-container { 
                display: none !important; 
                visibility: hidden !important;
                opacity: 0 !important;
            }
        }
    </style>
</noscript>

<script>
if (window.innerWidth <= 768) {
  document.write('<style>.fixed-video-container{display:none!important}</style>');
}

// Немедленное выполнение, устанавливаем стиль до загрузки DOM
(function() {
    // Установка фиксированной начальной прозрачности
    function setInitialOpacity() {
        const container = document.querySelector('.fixed-important-posts-container');
        if (container) {
            container.style.opacity = '1';
            container.style.visibility = 'visible';
        }
    }
    
    // Выполняем сразу
    setInitialOpacity();
    
    // И еще раз, когда DOM загружен
    document.addEventListener('DOMContentLoaded', setInitialOpacity);
})();

// Функция для проверки, находимся ли мы на главной странице
function isHomePage() {
    // Получаем текущий путь без хоста и параметров
    const path = window.location.pathname;
    
    // Проверяем, является ли это главной страницей (/ или /index.html)
    return path === '/' || path === '/index.html' || path === '/index.php';
}

// Функция для скрытия контейнера с закрепом на не-главных страницах (только для ПК)
function toggleFixedPostsVisibility() {
    // Не делаем ничего для мобильной версии
    if (window.innerWidth <= 768) {
        return;
    }
    
    const container = document.querySelector('.fixed-important-posts-container');
    const videoContainer = document.querySelector('.fixed-video-container');
    
    if (!container) return;
    
    if (isHomePage()) {
        // Устанавливаем стили для плавного появления
        container.style.display = 'block';
        container.style.visibility = 'visible';
        // Не меняем opacity здесь, чтобы избежать резкого перехода
        // Показываем видео-контейнер только на главной странице
        if (videoContainer) {
            if (window.innerWidth > 768) {
                videoContainer.removeAttribute('hidden');
                videoContainer.style.display = 'block';
                videoContainer.style.visibility = 'visible';
            } else {
                videoContainer.setAttribute('hidden', '');
                videoContainer.style.display = 'none';
                videoContainer.style.visibility = 'hidden';
            }
        }
    } else {
        container.style.display = 'none';
        container.style.visibility = 'hidden';
        // Не меняем opacity здесь, чтобы избежать резкого перехода при возврате
        // Скрываем видео-контейнер на всех страницах, кроме главной
        if (videoContainer) {
            videoContainer.setAttribute('hidden', '');
            videoContainer.style.display = 'none';
            videoContainer.style.visibility = 'hidden';
        }
    }
}

// Функция для скрытия контейнера при прокрутке (только для ПК)
function handleScroll() {
    // Не делаем ничего для мобильной версии
    if (window.innerWidth <= 768) {
        return;
    }
    
    const container = document.querySelector('.fixed-important-posts-container');
    const videoContainer = document.querySelector('.fixed-video-container');
    
    if (!container) return;
    
    // Получаем текущую позицию прокрутки
    const scrollPosition = window.scrollY || document.documentElement.scrollTop;
    
    // Начинаем скрывать при прокрутке больше 100px
    if (scrollPosition > 100) {
        container.classList.add('hide-on-scroll-active');
        
        // Скрываем видео при прокрутке вниз
        if (videoContainer) {
            videoContainer.classList.add('video-hide');
        }
    } else {
        container.classList.remove('hide-on-scroll-active');
        
        // Показываем видео только на главной странице и только вверху
        if (videoContainer && isHomePage()) {
            videoContainer.classList.remove('video-hide');
        } else if (videoContainer) {
            videoContainer.classList.add('video-hide');
        }
    }
}

// Запуск при загрузке страницы
document.addEventListener('DOMContentLoaded', function() {
    toggleFixedPostsVisibility();
    handleScroll(); // Проверяем начальное положение прокрутки
    
    // Инициализация видео-контейнера
    initVideoContainer();
});

// Запуск при изменении истории (навигации по сайту)
window.addEventListener('popstate', function() {
    toggleFixedPostsVisibility();
    handleScroll();
});

// Обработчик прокрутки страницы
window.addEventListener('scroll', handleScroll);

// Запускаем при загрузке страницы и после завершения переходов
try {
    if (typeof swup !== 'undefined') {
        swup.hooks.on('page:view', function() {
            toggleFixedPostsVisibility();
            handleScroll();
            initVideoContainer(); // Переинициализируем видео при навигации через swup
        });
    }
} catch (e) {}

// Функция инициализации видео-контейнера
function initVideoContainer() {
    const videoContainer = document.querySelector('.fixed-video-container');
    const videoElement = document.getElementById('loopVideo');
    const fullscreenContainer = document.getElementById('fullscreen-video-container');
    const fullscreenVideo = document.getElementById('fullscreenVideo');
    const closeButton = document.getElementById('close-fullscreen');
    
    // Проверяем видимость видео на основе текущей страницы
    if (videoElement && isHomePage()) {
        console.log("Инициализация видео на главной странице");
        
        // Устанавливаем начальное состояние видимости
        if (videoContainer) {
            // Показываем только если в верхней части страницы
            const scrollPosition = window.scrollY || document.documentElement.scrollTop;
            if (scrollPosition <= 100) {
                videoContainer.classList.remove('hide-on-scroll-active');
            } else {
                videoContainer.classList.add('hide-on-scroll-active');
            }
        }
        
        // Автозапуск видео
        try {
            videoElement.play()
                .catch(err => console.error("Ошибка при запуске видео:", err));
        } catch(e) {
            console.error("Ошибка воспроизведения:", e);
        }
        
        // Предзагрузка полноэкранного видео
        if (fullscreenVideo) {
            fullscreenVideo.preload = "auto";
            fullscreenVideo.load();
        }
    } else if (videoContainer) {
        // На других страницах скрываем видео
        videoContainer.classList.add('hide-on-scroll-active');
    }
    
    // Обработчик клика на видео-контейнер (ПК)
    if (videoContainer) {
        videoContainer.addEventListener('click', function(e) {
            e.stopPropagation();
            fullscreenContainer.style.display = 'flex';
            fullscreenVideo.currentTime = 0;
            fullscreenVideo.play();
            if (videoElement) {
                videoElement.pause();
            }
        });
    }
    // Кнопка закрытия (ПК)
    if (closeButton) {
        closeButton.addEventListener('click', function() {
            fullscreenContainer.style.display = 'none';
            if (fullscreenVideo) {
                fullscreenVideo.pause();
            }
            if (videoElement && videoElement.paused) {
                videoElement.play().catch(e => {
                    console.warn('Не удалось запустить малое видео:', e);
                });
            }
        });
    }
    // Закрытие по клику вне видео (ПК)
    if (fullscreenContainer) {
        fullscreenContainer.addEventListener('click', function(e) {
            if (e.target === fullscreenContainer) {
                fullscreenContainer.style.display = 'none';
                if (fullscreenVideo) {
                    fullscreenVideo.pause();
                }
                if (videoElement && videoElement.paused) {
                    videoElement.play().catch(e => {
                        console.warn('Не удалось запустить малое видео:', e);
                    });
                }
            }
        });
    }
    
    // Закрытие по ESC (устанавливаем только один раз для страницы)
    if (!window._hasEscHandler) {
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && fullscreenContainer && 
                fullscreenContainer.style.display === 'flex') {
                fullscreenContainer.style.display = 'none';
            }
        });
        
        // Отмечаем, что обработчик ESC установлен
        window._hasEscHandler = true;
    }
}
</script>

<style>
