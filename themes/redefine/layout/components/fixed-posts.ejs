        --primary-color-rgb: 71, 161, 255;
    }
    
    /* Сначала скрываем на мобильных устройствах без анимации */
    @media screen and (max-width: 768px) {
        .hide-on-mobile {
            display: none !important;
            visibility: hidden !important;
            opacity: 0 !important;
            width: 0 !important;
            height: 0 !important;
        }
        
        /* Дополнительный стиль для мобильной версии */
        /* При открытом видео скрываем все фиксированные контейнеры */
        body.video-is-open .fixed-important-posts-container,
        body:has(#fullscreen-video-container-mobile[style*="display: flex"]) .fixed-important-posts-container,
        body:has(#fullscreen-video-container-mobile[style*="display:flex"]) .fixed-important-posts-container {
            z-index: -10 !important;
            opacity: 0 !important;
            pointer-events: none !important;
        }
    }
    
    .fixed-important-posts-container {
        position: fixed !important;
        top: 80px !important;
        right: 40px !important;
        z-index: 1000 !important;
        max-width: 300px;
        display: block;
        opacity: 1 !important; /* Заставляем быть непрозрачным сразу */
        will-change: transform; /* Подсказка браузеру оптимизировать только трансформацию */
        transition: transform 1.2s cubic-bezier(0.25, 1, 0.5, 1); /* Убираем анимацию opacity */
    }
    
    /* Стили для скрытия при прокрутке */
    .hide-on-scroll-active {
        opacity: 0 !important;
        transform: translateY(-20px) !important;
        pointer-events: none !important;
        transition: opacity 1.2s cubic-bezier(0.25, 1, 0.5, 1), transform 1.2s cubic-bezier(0.25, 1, 0.5, 1); /* Восстанавливаем исходное время анимации */
