/* Добавляем ограничение для изображений с соотношением сторон 1:1 */
@media screen and (min-width: 768px) {
  .article-content img[src*="/images/DMT-Synesthesia-Language-Alchemy.jpg"] {
    max-width: 50% !important;
    height: auto !important;
    display: block;
    margin: 0 auto;
  }
  
  /* Универсальное правило для изображений с соотношением сторон близким к 1:1 */
  .article-content img {
    aspect-ratio: attr(width) / attr(height);
  }
  
  .article-content img[style*="aspect-ratio: 1/1"],
  .article-content img[style*="aspect-ratio:1/1"],
  .article-content img[width][height][width=height] {
    max-width: 50% !important;
    height: auto !important;
    display: block;
    margin: 0 auto;
  }
} 

// Кастомные стили для сайта с интеграцией Medium

// Кастомизация для iv-articles
.medium-article-container {
  max-width: 800px;
  margin: 0 auto;
  padding: 0 20px;
}

// Адаптация существующих стилей article для Medium-статей
.medium-article .article {
  font-family: 'Charter', 'Fira Sans', sans-serif;
  color: rgba(41, 41, 41, 1);
}

// Поддержка стилей телеграф-статей из Medium
.medium-article .article .tl_article_content {
  width: 100%;
  max-width: 100%;
  font-family: inherit;
  line-height: inherit;
  letter-spacing: inherit;
  color: inherit;
}

// Сохраняем оригинальную верстку для _tl_editor
#_tl_editor {
  width: auto !important;
  max-width: none !important;
  margin: 0 !important;
  padding: 0 !important;
}

// Поддержка темного режима
[data-theme="dark"] .medium-article .article {
  color: rgba(230, 230, 230, 1);
}

// Глобальное переопределение стилей изображений в Medium-статьях
.medium-article img {
  max-width: 100%;
  height: auto;
  margin: 2em auto;
  display: block;
}

// Улучшение отображения iframe (видео) в Medium-статьях
.medium-article iframe {
  max-width: 100%;
  width: 100%;
  margin: 2em auto;
  display: block;
  aspect-ratio: 16/9;
  border-radius: 8px;
}

// Улучшение отображения блоков кода
.medium-article pre {
  background-color: rgba(242, 242, 242, 1);
  padding: 1.5em;
  overflow-x: auto;
  border-radius: 5px;
  margin: 2em 0;
}

[data-theme="dark"] .medium-article pre {
  background-color: rgba(30, 30, 30, 1);
}

// Стилизация блоков цитат
.medium-article blockquote {
  margin: 2em 0;
  padding: 1em 1.5em;
  border-left: 3px solid;
  background: transparent;
  font-style: italic;
}

// Оформление заголовков статей
.medium-article h1, 
.medium-article h2,
.medium-article h3 {
  font-weight: 700;
  margin-top: 2em;
  margin-bottom: 0.6em;
}

// Адаптация под мобильные устройства
@media screen and (max-width: 768px) {
  .medium-article-container {
    padding: 0 15px;
  }
  
  .medium-article img {
    margin: 1.5em auto;
  }
  
  .medium-article iframe {
    margin: 1.5em auto;
  }
}

// Стилизация авторского блока
.medium-article-author {
  display: flex;
  align-items: center;
  margin: 30px 0;
  padding: 15px;
  border-radius: 8px;
  background: rgba(245, 245, 245, 0.5);
}

[data-theme="dark"] .medium-article-author {
  background: rgba(30, 30, 30, 0.5);
}

// Плавные переходы между темами
.medium-article, 
.medium-article .article,
.medium-article blockquote,
.medium-article pre,
.medium-article-author {
  transition: background-color 0.3s ease, color 0.3s ease;
}

// Фикс для Medium класса is-imageBackgrounded
.is-imageBackgrounded {
  margin-bottom: 20px;
  max-width: 100%;
  overflow: hidden;
}

.is-imageBackgrounded img {
  width: 100%;
  height: auto;
  border-radius: 5px;
  margin: 0 !important; // Переопределяем отступы для заглавных изображений
}

/* Стили совместимые с Telegram Instant View */
article.tl_article_content {
  display: block !important;
  min-width: 100% !important;
  max-width: 100% !important;
  width: 100% !important;
  margin: 0 !important;
  padding: 0 !important;
  box-sizing: border-box !important;
}

/* Чистое отображение изображений для Telegram Instant View */
article.tl_article_content figure {
  margin: 20px 0 !important;
  max-width: 100% !important;
  padding: 0 !important;
  width: auto !important;
  display: block !important;
  text-align: center !important;
  background: none !important;
  box-shadow: none !important;
  border: none !important;
}

article.tl_article_content figure img {
  max-width: 100% !important;
  height: auto !important;
  display: block !important;
  margin: 0 auto !important; 
  border: none !important;
  box-shadow: none !important;
  border-radius: 0 !important;
}

article.tl_article_content figcaption {
  display: block !important;
  font-size: 14px !important;
  line-height: 1.4 !important;
  color: inherit !important;
  opacity: 0.7 !important;
  margin-top: 8px !important;
  text-align: center !important;
  max-width: 100% !important;
  width: 100% !important;
}

/* Сброс дополнительных стилей для чистоты */
article.tl_article_content * {
  font-family: inherit !important;
  line-height: inherit !important;
}

/* Убираем нежелательные стили для Telegram Instant View */
article.tl_article_content div,
article.tl_article_content p,
article.tl_article_content h1,
article.tl_article_content h2,
article.tl_article_content h3,
article.tl_article_content h4,
article.tl_article_content h5,
article.tl_article_content h6,
article.tl_article_content ul,
article.tl_article_content ol,
article.tl_article_content li,
article.tl_article_content blockquote {
  background: none !important;
  box-shadow: none !important;
  text-shadow: none !important;
}

// Глобальные стили для article.tl_article_content и _tl_editor для всех статей
.article-content article.tl_article_content#_tl_editor,
.markdown-body article.tl_article_content#_tl_editor {
  box-sizing: border-box !important;
  display: block !important;
  width: 100% !important;
  max-width: 100% !important;
  min-width: 100% !important;
  margin: 0 !important;
  padding: 0 !important;
  overflow: visible !important;
  font-family: inherit !important;
  font-size: inherit !important;
  line-height: inherit !important;
}

// Усиление специфичности для критичных элементов
.article-content .article.medium-article article.tl_article_content#_tl_editor p,
.article-content .article.medium-article article.tl_article_content#_tl_editor h1,
.article-content .article.medium-article article.tl_article_content#_tl_editor h2,
.article-content .article.medium-article article.tl_article_content#_tl_editor h3,
.article-content .article.medium-article article.tl_article_content#_tl_editor ul,
.article-content .article.medium-article article.tl_article_content#_tl_editor ol,
.article-content .article.medium-article article.tl_article_content#_tl_editor blockquote {
  font-family: inherit !important;
  line-height: inherit !important;
}

// Фикс для article.tl_article_content и id=_tl_editor
.tl_article_content, 
#_tl_editor {
  display: block !important;
  width: 100% !important;
  max-width: 100% !important;
  margin: 0 !important;
  padding: 0 !important;
  font-family: inherit;
  font-size: inherit;
  line-height: inherit;
}

// Специфичные стили для Medium статей
article.tl_article_content#_tl_editor {
  min-width: 100% !important;
  box-sizing: border-box !important;
  overflow: visible !important;
} 